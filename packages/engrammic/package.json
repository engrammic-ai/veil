{
	"name": "@engrammic/veil",
	"version": "0.0.1",
	"description": "Context management for Veil - dynamic loading, heuristic eviction, episodic memory",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./cold": {
			"types": "./dist/cold/index.d.ts",
			"import": "./dist/cold/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsc",
		"test": "vitest --run"
	},
	"dependencies": {
		"better-sqlite3": "11.10.0",
		"web-tree-sitter": "0.25.6"
	},
	"devDependencies": {
		"@types/better-sqlite3": "7.6.13",
		"@vitest/coverage-v8": "3.2.4",
		"shx": "0.4.0",
		"tsx": "4.22.1",
		"typescript": "5.9.3",
		"vitest": "3.2.4"
	},
	"peerDependencies": {
		"@getzep/zep-cloud": "^2.0.0",
		"@lancedb/lancedb": "^0.15.0",
		"chromadb": "^1.9.0"
	},
	"peerDependenciesMeta": {
		"@getzep/zep-cloud": { "optional": true },
		"@lancedb/lancedb": { "optional": true },
		"chromadb": { "optional": true }
	}
}
