  "devDependencies": {
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "22.14.1",
    "typescript": "5.7.3",
    "vitest": "3.0.7"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
