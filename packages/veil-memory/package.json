{
  "name": "@veil/memory",
  "version": "0.1.0",
  "description": "FSRS-powered memory companion for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
