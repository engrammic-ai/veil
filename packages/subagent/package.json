	},
	"dependencies": {
		"@engrammic/veil-context": "workspace:*",
		"better-sqlite3": "11.10.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "7.6.13",
		"shx": "0.4.0",
		"typescript": "5.9.3",
		"vitest": "3.2.4"
	}
