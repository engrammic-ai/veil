{
	"name": "@veil/subagent",
	"version": "0.1.45",
	"description": "Subagent orchestration with Veil context propagation",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
