+export interface IntentNode {
+	id: string;
+	type: "primary" | "sub";
+	content: string;
+
+	confidence: "explicit" | "inferred";
+	source: "user" | "brainstorm" | "plan" | "agent";
+
+	status: "active" | "completed" | "abandoned" | "pending";
+	createdAt: number;
+	completedAt?: number;
+
+	supersedes?: string;
+
+	parent?: string;
+
+	current?: boolean;
+}
+
+export interface ProjectIntent {
+	id: string;
+	content: string;
+	status: "active" | "completed" | "paused";
+	createdAt: number;
+	updatedAt: number;
+
+	supersedes?: string;
+
+	phases?: Array<{
+		id: string;
+		content: string;
+		status: "completed" | "active" | "pending";
+	}>;
+}
+
+export interface ProjectIntentFile {
+	current: string | null;
+	intents: Record<string, ProjectIntent>;
+	history: string[];
+}
+
+export interface SessionIntent extends IntentNode {
+	// Links session intent to project
+	projectIntentId?: string; // which project intent this serves
+	projectPhaseId?: string; // which phase of project intent
+
+	// Session scoping
+	sessionId: string;
+}
